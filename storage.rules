rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Make absolutely all storage paths 100% public for reading
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Past papers - authenticated upload
    match /Past-papers/{allPaths=**} {
      allow write: if request.auth != null;
    }
    match /past-papers/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // Resources — anyone can upload under 20MB
    match /resources/{allPaths=**} {
      allow write: if request.resource.size < 20 * 1024 * 1024;
    }
    // Discussion images — anyone uploads under 5MB
    match /discussion-images/{allPaths=**} {
      allow write: if request.resource.size < 5 * 1024 * 1024;
    }
  }
}
